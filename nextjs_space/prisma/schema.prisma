generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/videdge-mvp/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  videoIdeas    VideoIdea[]
  scripts       Script[]
  projects      Project[]
  accounts      Account[]
  sessions      Session[]
  youtubeSearches    YouTubeSearch[]
  youtubeVideos      YouTubeVideo[]
  youtubeChannels    YouTubeChannel[]
  nicheOpportunities NicheOpportunity[]
  pipelineSessions   PipelineSession[]
  thumbnailConcepts  ThumbnailConcept[]
  patternAnalyses    PatternAnalysis[]
  growthPlans        GrowthPlan[]
  apiProvider        String?
  apiKey             String?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model VideoIdea {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  niche                 String
  audience              String
  objective             String
  duration              String
  tone                  String
  title                 String
  alternativeTitle      String?
  hook                  String   @db.Text
  promise               String   @db.Text
  summaryStructure      String   @db.Text
  viralPotential        Int
  productionDifficulty  Int
  strategicReason       String   @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  scripts               Script[]
  projects              Project[]

  @@index([userId])
}

model Script {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoIdeaId         String
  videoIdea           VideoIdea @relation(fields: [videoIdeaId], references: [id], onDelete: Cascade)
  title               String
  description         String    @db.Text
  hook                String    @db.Text
  introduction        String    @db.Text
  sectionOne          String    @db.Text
  sectionTwo          String    @db.Text
  sectionThree        String    @db.Text
  sectionFour         String    @db.Text
  conclusion          String    @db.Text
  cta                 String    @db.Text
  brollSuggestions    String    @db.Text
  visualSuggestions   String    @db.Text
  musicSuggestions    String    @db.Text
  estimatedDuration   String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  project             Project?

  @@index([userId])
  @@index([videoIdeaId])
}

model Project {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String     @default("")
  niche       String     @default("")
  videoIdeaId String?
  videoIdea   VideoIdea? @relation(fields: [videoIdeaId], references: [id], onDelete: SetNull)
  scriptId    String?    @unique
  script      Script?    @relation(fields: [scriptId], references: [id], onDelete: SetNull)
  status      String     @default("Ideia")
  assignee    String?
  deadline    DateTime?
  priority    String     @default("média")
  notes       String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
  @@index([status])
}

model YouTubeSearch {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query     String
  country   String?
  language  String?
  period    String?
  category  String?
  resultCount Int    @default(0)
  createdAt DateTime @default(now())

  @@index([userId])
}

model YouTubeVideo {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  youtubeVideoId        String
  title                 String
  description           String?  @db.Text
  videoUrl              String
  thumbnailUrl          String?
  channelId             String?
  channelTitle          String?
  publishedAt           DateTime?
  viewCount             Int      @default(0)
  likeCount             Int      @default(0)
  commentCount          Int      @default(0)
  duration              String?
  tags                  String?  @db.Text
  viralScore            Int      @default(0)
  viewsPerDay           Float    @default(0)
  viewsSubscriberRatio  Float    @default(0)
  engagementRate        Float    @default(0)
  detectedNiche         String?
  searchQuery           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([userId, youtubeVideoId])
  @@index([userId])
  @@index([viralScore])
}

model YouTubeChannel {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  youtubeChannelId      String
  title                 String
  channelUrl            String?
  description           String?  @db.Text
  subscriberCount       Int      @default(0)
  totalViewCount        BigInt   @default(0)
  videoCount            Int      @default(0)
  country               String?
  thumbnailUrl          String?
  estimatedMonthlyViews Int?
  revenueConservative   Float?
  revenueAverage        Float?
  revenueAggressive     Float?
  revenueConfidence     String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([userId, youtubeChannelId])
  @@index([userId])
}

model NicheOpportunity {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  niche                 String
  subniche              String?
  description           String?  @db.Text
  referenceVideoId      String?
  referenceVideoTitle   String?
  referenceChannelTitle String?
  averageViews          Int?
  averageViewsPerDay    Float?
  competitionLevel      String?
  opportunityLevel      String?
  monetizationPotential String?
  productionDifficulty  String?
  mainChannels          String?  @db.Text
  topVideos             String?  @db.Text
  aiAnalysis            String?  @db.Text
  viralScore            Int?
  estimatedRevenue      String?
  suggestedAngle        String?  @db.Text
  risks                 String?  @db.Text
  derivedIdeas          String?  @db.Text
  status                String   @default("nova")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model RPMBenchmark {
  id              String   @id @default(cuid())
  niche           String
  country         String   @default("global")
  language        String   @default("all")
  rpmConservative Float
  rpmAverage      Float
  rpmAggressive   Float
  sourceNote      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([niche, country, language])
}

model PipelineSession {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  niche           String
  country         String?
  language        String?
  audience        String?
  channelType     String?
  channelGoal     String?
  videoDuration   String?
  contentTone     String?
  currentStage    Int      @default(1)
  youtubeData     String?  @db.Text
  stage1Result    String?  @db.Text
  stage2Result    String?  @db.Text
  stage3Result    String?  @db.Text
  stage4Result    String?  @db.Text
  stage5Result    String?  @db.Text
  selectedIdeaIdx Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model ThumbnailConcept {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoTitle        String
  niche             String
  emotion           String?
  style             String?
  conceptName       String
  visualIdea        String   @db.Text
  thumbnailText     String?
  emotionGenerated  String?
  mainElements      String?  @db.Text
  composition       String?  @db.Text
  suggestedColors   String?
  imageStyle        String?
  aiImagePrompt     String?  @db.Text
  clickReason       String?  @db.Text
  riskNote          String?
  abTestSuggestion  String?
  pipelineSessionId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
}

model PatternAnalysis {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  niche             String
  query             String?
  videosAnalyzed    Int      @default(0)
  analysisResult    String   @db.Text
  pipelineSessionId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
}

model GrowthPlan {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  niche             String
  channelLevel      String?
  planResult        String   @db.Text
  pipelineSessionId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
}