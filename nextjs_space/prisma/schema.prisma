generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/videdge-mvp/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  videoIdeas    VideoIdea[]
  scripts       Script[]
  projects      Project[]
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model VideoIdea {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  niche                 String
  audience              String
  objective             String
  duration              String
  tone                  String
  title                 String
  alternativeTitle      String?
  hook                  String   @db.Text
  promise               String   @db.Text
  summaryStructure      String   @db.Text
  viralPotential        Int
  productionDifficulty  Int
  strategicReason       String   @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  scripts               Script[]
  projects              Project[]

  @@index([userId])
}

model Script {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoIdeaId         String
  videoIdea           VideoIdea @relation(fields: [videoIdeaId], references: [id], onDelete: Cascade)
  title               String
  description         String    @db.Text
  hook                String    @db.Text
  introduction        String    @db.Text
  sectionOne          String    @db.Text
  sectionTwo          String    @db.Text
  sectionThree        String    @db.Text
  sectionFour         String    @db.Text
  conclusion          String    @db.Text
  cta                 String    @db.Text
  brollSuggestions    String    @db.Text
  visualSuggestions   String    @db.Text
  musicSuggestions    String    @db.Text
  estimatedDuration   String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  project             Project?

  @@index([userId])
  @@index([videoIdeaId])
}

model Project {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String     @default("")
  niche       String     @default("")
  videoIdeaId String?
  videoIdea   VideoIdea? @relation(fields: [videoIdeaId], references: [id], onDelete: SetNull)
  scriptId    String?    @unique
  script      Script?    @relation(fields: [scriptId], references: [id], onDelete: SetNull)
  status      String     @default("Ideia")
  assignee    String?
  deadline    DateTime?
  priority    String     @default("média")
  notes       String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
  @@index([status])
}